# Monorepo Root GitIgnore

# Dependencies
node_modules/
.pnp
.pnp.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/
*.egg

# Environment
.env
.env.local
.env.*
!.env.example

# Storage & Uploads
Lumina-backend/storage/*
!Lumina-backend/storage/.gitkeep
Lumina-backend/uploads/
*.sql
*.json_backup

# Next.js
.next/
out/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Testing
coverage/
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
